# ======================== APPLICATION SETTINGS ========================
APP_NAME=TeaBlendAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# ======================== API CONFIGURATION ========================
API_HOST=0.0.0.0
API_PORT=5000
API_RELOAD=True
API_V1_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://frontend:3000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ======================== DATABASE CONFIGURATION ========================
# Option 1: Direct connection string
# DATABASE_URL=mssql+pyodbc://username:password@server/database?driver=ODBC+Driver+17+for+SQL+Server

# Option 2: Individual MSSQL settings
MSSQL_SERVER=localhost
MSSQL_DATABASE=teablendai_db
MSSQL_USERNAME=sa
MSSQL_PASSWORD=YourPassword123
MSSQL_PORT=1433
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_ENCRYPT=True
MSSQL_TRUST_SERVER_CERTIFICATE=True
DB_TRUSTED_CONNECTION=False

# Database Pool Settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ======================== AUTHENTICATION & SECURITY ========================
# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ======================== PASSWORD RESET CONFIGURATION ========================
# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# ======================== EMAIL/SMTP CONFIGURATION ========================
# Gmail SMTP Example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Alternative: Using other SMTP providers
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key

# Alternative: Using AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-username
# SMTP_PASSWORD=your-ses-password
# SMTP_FROM_EMAIL=verified-sender@yourdomain.com

# ======================== AI/ML CONFIGURATION ========================
GOOGLE_API_KEY=your-google-api-key
MODEL_NAME=gemini-1.5-flash

# ======================== LOGGING ========================
LOG_LEVEL=INFO
LOG_FORMAT=%(levelname)s:%(name)s:%(message)s

# ======================== CHAT CONFIGURATION ========================
MAX_CONVERSATION_HISTORY=50
CHAT_TIMEOUT_SECONDS=30
ENABLE_TOPIC_VALIDATION=True

# ======================== FRONTEND CONFIGURATION ========================
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ======================== MCP SERVERS ========================
# These paths are set automatically, but can be overridden if needed
# MCP_DATABASE_SERVER_PATH=/path/to/database/server.py
# MCP_SEARCH_SERVER_PATH=/path/to/search/server.py
# MCP_VISUALIZATION_SERVER_PATH=/path/to/visualization/server.py

# ======================== ADDITIONAL SETTINGS ========================
# Rate Limiting (if implemented)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Feature Flags
ENABLE_GOOGLE_AUTH=True
ENABLE_PASSWORD_RESET=True
ENABLE_EMAIL_VERIFICATION=False

# ======================== NOTES ========================
# 1. For Gmail:
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Enable 2FA first
#
# 2. For Production:
#    - Change JWT_SECRET_KEY to random 32+ character string
#    - Set DEBUG=False
#    - Set ENVIRONMENT=production
#    - Use HTTPS/TLS everywhere
#    - Store secrets in secure vault (AWS Secrets Manager, etc.)
#
# 3. Database:
#    - Ensure MSSQL Server is installed and running
#    - Create database before running migrations
#    - Run: alembic upgrade head
#
# 4. Email:
#    - Test email configuration before deployment
#    - Consider using transactional email service (SendGrid, AWS SES)
#    - Monitor email delivery rates
#
# 5. Frontend:
#    - Update NEXT_PUBLIC_API_BASE_URL for your deployment
#    - Get Google Client ID from Google Cloud Console
