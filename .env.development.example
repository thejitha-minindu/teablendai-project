# .env.development
# Development environment configuration

# DATABASE CONFIGURATION ( Remote Azure SQL Database )
DB_HOST=your-remote-db-host.database.windows.net
DB_PORT=1433
DB_NAME=teablend_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# AZURE AI CONFIGURATION ( if any )
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/



# APPLICATION SETTINGS
# SECRET_KEY=dev_secret_key_change_in_production
# JWT_SECRET_KEY=dev_jwt_secret_key_change_in_production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=30


# ENVIRONMENT
ENVIRONMENT=development
DEBUG=True


# BACKEND CONFIGURATION
# Used by backend to know its own URL
BACKEND_HOST=backend
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000


# FRONTEND CONFIGURATION
# IMPORTANT: For Docker internal communication, use service name 'backend'
# For browser access from host machine, use 'localhost'
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development


# Hot reload settings for Docker
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true


# CORS CONFIGURATION
# Frontend URLs that backend should allow
CORS_ORIGINS=http://localhost:3000,http://frontend:3000