# .env.development
# Development environment configuration

# Database Configuration (MSSQL / Azure SQL)
# Option A: Configure with MSSQL_* variables
MSSQL_SERVER=your-server.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=TeablendAI
MSSQL_USERNAME=your_sql_user
MSSQL_PASSWORD=your_password
DB_TRUSTED_CONNECTION=false
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_ENCRYPT=yes
MSSQL_TRUST_SERVER_CERTIFICATE=no

# Option B: full SQLAlchemy URL (takes precedence over MSSQL_* when set)
# DATABASE_URL=mssql+pyodbc://your_sql_user:your_password@your-server.database.windows.net,1433/TeablendAI?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# AZURE AI CONFIGURATION ( if any )
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000, http://127.0.0.1:3000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_ENVIRONMENT=development


# APPLICATION SETTINGS
# SECRET_KEY=dev_secret_key_change_in_production
# JWT_SECRET_KEY=dev_jwt_secret_key_change_in_production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=30


# ENVIRONMENT
ENVIRONMENT=development
DEBUG=True

# Hot reload settings for Docker
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Logging
LOG_LEVEL=INFO
